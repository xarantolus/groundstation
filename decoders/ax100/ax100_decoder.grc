- [freq_xlating_fir_filter_xxx_0, '0', satellites_fsk_demodulator_0, '0']
- [pdu_pdu_to_stream_x_0, '0', blocks_file_sink_0, '0']
- [satellites_fixedlen_to_pdu_0, pdus, satellites_u482c_decode_0, in]
- [satellites_fsk_demodulator_0, '0', digital_binary_slicer_fb_0, '0']
